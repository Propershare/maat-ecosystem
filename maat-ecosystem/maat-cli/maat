#!/usr/bin/env python3
"""
maat — Ka Architecture CLI

The body speaks through this interface.

Usage:
    maat status              Full body status — all organs, health, discovery
    maat health              Ka organ health check — ping all endpoints
    maat meter               Memory bank meter — capacity, latency, freshness
    maat discover            Print discovery manifest (what agents see)
    maat organs              List all nine organs with status
    maat organ <name>        Show detail for one organ
    maat boot                Run boot sequence — check soul, identity, memory, ka, senses

    maat memory search <q>   Search memory
    maat memory write <text> Write a memory entry
    maat memory stats        Memory statistics
    maat memory banks        Show active memory banks

    maat identity list       List registered agents
    maat identity show <id>  Show agent identity

    maat policy check        Check a policy evaluation
    maat events tail         Tail the event log

    maat apps list           List installed apps (hands/apps/)
    maat packs list          List installed packs (blood/packs/)

    maat evolve status       Evolution loop status
    maat evolve run          Trigger evolution cycle manually

    maat migrate             Export identity + memory for migration
"""

import sys
import os
import json
import argparse
import time
import socket
from pathlib import Path
from datetime import datetime, timezone

# Resolve ecosystem root
ECOSYSTEM_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(ECOSYSTEM_ROOT))

MAAT_HOME = Path.home() / ".maat"
MAAT_HOME.mkdir(parents=True, exist_ok=True)

# Ka Architecture organ → port map
ORGANS = {
    "soul":     {"port": None,  "type": "files", "path": "soul/",     "icon": "🔮"},
    "brain":    {"port": 8014,  "type": "mcp",   "server": "tehuti-core",  "icon": "🧠"},
    "memory":   {"port": 8022,  "type": "mcp",   "server": "maat-memory",  "icon": "💾"},
    "hands":    {"port": 8016,  "type": "mcp",   "server": "filesystem",   "icon": "🤲"},
    "senses":   {"port": 8015,  "type": "mcp",   "server": "n8n",          "icon": "👁"},
    "voice":    {"port": None,  "type": "planned",                         "icon": "🗣"},
    "ka":       {"port": 8010,  "type": "http",  "server": "ka-discovery", "icon": "🛡"},
    "skeleton": {"port": 8017,  "type": "mcp",   "server": "postgres",     "icon": "🦴"},
    "blood":    {"port": 8020,  "type": "mcp",   "server": "pipeline",     "icon": "🩸"},
}


def check_port(port):
    """Check if a port is alive."""
    try:
        sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
        sock.settimeout(2)
        result = sock.connect_ex(('127.0.0.1', port))
        sock.close()
        return result == 0
    except Exception:
        return False


def cmd_status(args):
    """Full body status."""
    manifest = ECOSYSTEM_ROOT / "MANIFEST.ka"
    soul = ECOSYSTEM_ROOT / "soul" / "constitution.md"
    identity = ECOSYSTEM_ROOT / "soul" / "identity.yaml"

    print()
    print("  ╔══════════════════════════════════════════╗")
    print("  ║         MAAT ECOSYSTEM — Ka Body         ║")
    print("  ╚══════════════════════════════════════════╝")
    print()

    # DNA
    print(f"  📜 MANIFEST.ka    {'✅ Found' if manifest.exists() else '❌ Missing'}")
    print(f"  🔮 Constitution   {'✅ Loaded' if soul.exists() else '❌ Missing'}")
    print(f"  🪪 Identity       {'✅ Loaded' if identity.exists() else '❌ Missing'}")
    print()

    # Organs
    alive = 0
    total_ports = 0
    print("  ORGANS:")
    for name, info in ORGANS.items():
        port = info.get("port")
        icon = info["icon"]
        if port:
            total_ports += 1
            up = check_port(port)
            if up:
                alive += 1
            status = f"✅ :{port}" if up else f"❌ :{port}"
        elif info["type"] == "files":
            organ_path = ECOSYSTEM_ROOT / info.get("path", "")
            status = "✅ files" if organ_path.exists() else "❌ missing"
        else:
            status = "⏳ planned"
        
        server = info.get("server", "")
        print(f"    {icon} {name:12s} {status:15s}  {server}")

    print()
    print(f"  Health: {alive}/{total_ports} organs online")

    # Apps
    apps_dir = ECOSYSTEM_ROOT / "hands" / "apps"
    if apps_dir.exists():
        apps = [d.name for d in apps_dir.iterdir() if d.is_dir() and (d / "manifest.json").exists()]
        if apps:
            print(f"  Apps:   {', '.join(apps)}")

    # Packs
    packs_dir = ECOSYSTEM_ROOT / "blood" / "packs"
    if packs_dir.exists():
        for pack_type in ["policy-packs", "tool-packs", "agent-packs", "learning-packs"]:
            p = packs_dir / pack_type
            if p.exists():
                packs = [d.name for d in p.iterdir() if d.is_dir()]
                if packs:
                    print(f"  {pack_type}: {', '.join(packs)}")

    print()


def cmd_health(args):
    """Ka organ health check."""
    print()
    print("  🛡 Ka Health Check")
    print("  ─────────────────────────────────────")
    
    total = 0
    alive = 0
    for name, info in ORGANS.items():
        port = info.get("port")
        if not port:
            continue
        total += 1
        start = time.time()
        up = check_port(port)
        latency = (time.time() - start) * 1000
        
        if up:
            alive += 1
            print(f"    ✅ {name:12s}  :{port}  {latency:.0f}ms")
        else:
            print(f"    ❌ {name:12s}  :{port}  DEAD")
    
    print(f"  ─────────────────────────────────────")
    overall = "HEALTHY" if alive == total else "DEGRADED" if alive > total // 2 else "CRITICAL"
    print(f"    Score: {alive}/{total} — {overall}")
    print()


def cmd_meter(args):
    """Memory bank meter."""
    meter_script = ECOSYSTEM_ROOT / "memory" / "meter.py"
    if meter_script.exists():
        os.execv(sys.executable, [sys.executable, str(meter_script)] + sys.argv[2:])
    else:
        print("❌ memory/meter.py not found")


def cmd_discover(args):
    """Print discovery manifest."""
    try:
        import urllib.request
        resp = urllib.request.urlopen("http://localhost:8010/manifest", timeout=3)
        data = json.loads(resp.read())
        print(json.dumps(data, indent=2))
    except Exception as e:
        print(f"❌ Discovery endpoint not reachable: {e}")
        print("   Start with: sudo systemctl start ka-discovery")


def cmd_organs(args):
    """List all nine organs."""
    print()
    print("  The Nine Organs")
    print("  ═══════════════════════════════════════════════")
    for name, info in ORGANS.items():
        icon = info["icon"]
        port = info.get("port")
        status = ""
        if port:
            up = check_port(port)
            status = f":{port} {'✅' if up else '❌'}"
        elif info["type"] == "files":
            status = "files"
        else:
            status = "planned"
        
        roles = {
            "soul": "Identity, governance, moral constitution",
            "brain": "Reasoning, model access, learning",
            "memory": "Persistence, recall, pattern recognition",
            "hands": "Action, tool use, external interaction",
            "senses": "Perception, event handling, triggers",
            "voice": "Communication, output, expression",
            "ka": "Health monitoring, self-healing, pain",
            "skeleton": "Schemas, contracts, interfaces",
            "blood": "Inter-organ communication, shared state",
        }
        print(f"    {icon} {name:12s}  {status:16s}  {roles.get(name, '')}")
    print()


def cmd_organ(args):
    """Show detail for one organ."""
    name = args.name.lower()
    if name not in ORGANS:
        print(f"❌ Unknown organ: {name}")
        print(f"   Available: {', '.join(ORGANS.keys())}")
        return
    
    info = ORGANS[name]
    icon = info["icon"]
    
    print(f"\n  {icon} {name.upper()}")
    print(f"  {'─' * 40}")
    print(f"  Type:   {info['type']}")
    
    if info.get("port"):
        up = check_port(info["port"])
        print(f"  Port:   {info['port']}")
        print(f"  Status: {'✅ alive' if up else '❌ dead'}")
    
    if info.get("server"):
        print(f"  Server: {info['server']}")
    
    if info.get("path"):
        organ_path = ECOSYSTEM_ROOT / info["path"]
        if organ_path.exists():
            files = list(organ_path.rglob("*"))
            dirs = [f for f in files if f.is_dir()]
            files = [f for f in files if f.is_file()]
            print(f"  Files:  {len(files)} files in {len(dirs)} dirs")
    
    print()


def cmd_boot(args):
    """Run boot sequence."""
    print()
    print("  🪶 Ka Boot Sequence")
    print("  ═══════════════════════════════════════")
    
    steps = [
        ("Read constitution", ECOSYSTEM_ROOT / "soul" / "constitution.md"),
        ("Load identity", ECOSYSTEM_ROOT / "soul" / "identity.yaml"),
        ("Check memory", None),
        ("Check Ka health", None),
        ("Activate senses", None),
    ]
    
    all_ok = True
    for i, (desc, path) in enumerate(steps, 1):
        if path:
            ok = path.exists()
        elif "memory" in desc:
            ok = check_port(8022)
        elif "Ka" in desc:
            ok = check_port(8010)
        elif "senses" in desc:
            ok = check_port(8015)
        else:
            ok = True
        
        status = "✅" if ok else "❌"
        if not ok:
            all_ok = False
        print(f"    {i}. {status} {desc}")
    
    print(f"\n    {'✅ READY — the body is alive' if all_ok else '⚠️  Boot incomplete — check failed organs'}")
    print()


