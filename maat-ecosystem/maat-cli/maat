def cmd_apps_list(args):
    """List installed apps."""
    apps_dir = ECOSYSTEM_ROOT / "hands" / "apps"
    if not apps_dir.exists():
        print("No apps installed.")
        return
    print("  Installed Apps (hands/apps/):")
    for d in sorted(apps_dir.iterdir()):
        manifest = d / "manifest.json"
        if manifest.exists():
            m = json.loads(manifest.read_text())
            print(f"    🤲 {m.get('name', d.name):20s}  {m.get('description', '')}")


def cmd_packs_list(args):
    """List installed packs."""
    packs_dir = ECOSYSTEM_ROOT / "blood" / "packs"
    if not packs_dir.exists():
        print("No packs installed.")
        return
    print("  Installed Packs (blood/packs/):")
    for pack_type in sorted(packs_dir.iterdir()):
        if pack_type.is_dir():
            for d in sorted(pack_type.iterdir()):
                if d.is_dir():
                    manifest = d / "manifest.json"
                    if manifest.exists():
                        m = json.loads(manifest.read_text())
                        print(f"    🩸 [{pack_type.name}] {m.get('name', d.name)}")


def cmd_evolve_status(args):
    """Evolution loop status."""
    evolve = ECOSYSTEM_ROOT / "ka" / "evolve.yaml"
    if evolve.exists():
        try:
            import yaml
            config = yaml.safe_load(evolve.read_text())
            evo = config.get("evolution", {})
            print(f"  Evolution Loop: {'✅ enabled' if evo.get('enabled') else '❌ disabled'}")
            print(f"  Cycle interval: {evo.get('cycle_interval', '?')}")
            print(f"  Min data threshold: {evo.get('min_data_threshold', '?')}")
            stages = ["sense", "store", "pattern", "promote", "apply", "measure", "decay"]
            print(f"  Stages: {' → '.join(s.upper() for s in stages)}")
        except ImportError:
            print(evolve.read_text())
    else:
        print("❌ ka/evolve.yaml not found")


def cmd_migrate(args):
    """Export for migration."""
    export = {
        "kind": "ka-migration",
        "exported_at": datetime.now(timezone.utc).isoformat(),
        "body": "maat-ecosystem",
    }

    identity = ECOSYSTEM_ROOT / "soul" / "identity.yaml"
    if identity.exists():
        export["identity"] = identity.read_text()

    constitution = ECOSYSTEM_ROOT / "soul" / "constitution.md"
    if constitution.exists():
        export["constitution_hash"] = str(hash(constitution.read_text()))

    out_path = Path(args.output or "maat-export.json")
    out_path.write_text(json.dumps(export, indent=2))
    print(f"  ✅ Exported to {out_path}")
    print(f"  Identity outlives implementation. 🏛️")


def main():
    parser = argparse.ArgumentParser(
        prog="maat",
        description="Ka Architecture CLI — the body speaks through this interface",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  maat status           Full body status
  maat health           Quick organ health check
  maat meter            Memory bank capacity meter
  maat boot             Run boot sequence
  maat organs           List all nine organs
  maat organ memory     Detail view of memory organ
  maat discover         Print the discovery manifest
  maat evolve status    Evolution loop config
  maat apps list        Installed apps
  maat packs list       Installed packs
"""
    )
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("status", help="Full body status")
    sub.add_parser("health", help="Ka organ health check")
    sub.add_parser("meter", help="Memory bank meter")
    sub.add_parser("discover", help="Print discovery manifest")
    sub.add_parser("organs", help="List all nine organs")
    sub.add_parser("boot", help="Run boot sequence")
    
    organ_p = sub.add_parser("organ", help="Show organ detail")
    organ_p.add_argument("name", help="Organ name")

    # memory
    mem_p = sub.add_parser("memory", help="Memory operations")
    mem_sub = mem_p.add_subparsers(dest="mem_cmd")
    mem_search = mem_sub.add_parser("search", help="Search memory")
    mem_search.add_argument("query")
    mem_search.add_argument("-n", "--limit", type=int, default=5)
    mem_sub.add_parser("stats", help="Memory statistics")
    mem_sub.add_parser("banks", help="Show memory banks config")

    # identity
    id_p = sub.add_parser("identity", help="Identity management")
    id_sub = id_p.add_subparsers(dest="id_cmd")
    id_sub.add_parser("list", help="List identities")

    # policy
    pol_p = sub.add_parser("policy", help="Policy operations")
    pol_sub = pol_p.add_subparsers(dest="pol_cmd")
    pol_check = pol_sub.add_parser("check", help="Check policy")
    pol_check.add_argument("agent")
    pol_check.add_argument("action")
    pol_check.add_argument("--ring", default="inner-ring")

    # events
    evt_p = sub.add_parser("events", help="Event log")
    evt_sub = evt_p.add_subparsers(dest="evt_cmd")
    evt_tail = evt_sub.add_parser("tail", help="Tail events")
    evt_tail.add_argument("-n", "--lines", type=int, default=20)

    sub.add_parser("apps", help="List apps").add_argument("list_cmd", nargs="?", default="list")
    sub.add_parser("packs", help="List packs").add_argument("list_cmd", nargs="?", default="list")
    
    # evolve
    evo_p = sub.add_parser("evolve", help="Evolution loop")
    evo_sub = evo_p.add_subparsers(dest="evo_cmd")
    evo_sub.add_parser("status", help="Evolution loop status")

    # migrate
    mig_p = sub.add_parser("migrate", help="Export for migration")
    mig_p.add_argument("-o", "--output", default="maat-export.json")

    args = parser.parse_args()

    commands = {
        "status": cmd_status,
        "health": cmd_health,
        "meter": cmd_meter,
        "discover": cmd_discover,
        "organs": cmd_organs,
        "organ": cmd_organ,
        "boot": cmd_boot,
        "apps": cmd_apps_list,
        "packs": cmd_packs_list,
        "migrate": cmd_migrate,
    }

    if args.command in commands:
        commands[args.command](args)
    elif args.command == "memory":
        if args.mem_cmd == "search": cmd_memory_search(args)
        elif args.mem_cmd == "stats": cmd_memory_stats(args)
        elif args.mem_cmd == "banks": cmd_memory_banks(args)
        else: mem_p.print_help()
    elif args.command == "identity":
        if args.id_cmd == "list": cmd_identity_list(args)
        else: id_p.print_help()
    elif args.command == "events":
        if args.evt_cmd == "tail": cmd_events_tail(args)
        else: evt_p.print_help()
    elif args.command == "evolve":
        if args.evo_cmd == "status": cmd_evolve_status(args)
        else: evo_p.print_help()
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
