{
  "name": "operator",
  "version": "1.0.0",
  "description": "System operator agent: manages infrastructure, deploys, monitors, maintains",
  "identity": {
    "name": "operator",
    "ring": "outer-ring",
    "role": "operator"
  },
  "policies": ["maat-apps/operator/policy.json"],
  "tools": ["execute", "read_file", "write_file", "deploy", "monitor"],
  "memory_rules": {
    "default_class": "task",
    "auto_consolidate": false,
    "retention_days": 180
  },
  "workflows": ["deploy", "diagnose", "maintain"]
}
